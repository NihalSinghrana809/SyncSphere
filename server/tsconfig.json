{
      "compilerOptions": {
            "target": "es6",
            "module": "NodeNext",
            "moduleResolution": "nodenext",
            "esModuleInterop": true,
            "allowImportingTsExtensions": true,
            "noEmit": true,
            "forceConsistentCasingInFileNames": true,
            "strict": true,
            "skipLibCheck": true,
            "resolveJsonModule": true,
            "isolatedModules": true,
            "types": [
                  "node"
            ],
            "outDir": "./dist",
            "rootDir": "./src"
      },
      "include": [
            "src/**/*"
      ],
      "exclude": [
            "node_modules",
            "dist"
      ]
}